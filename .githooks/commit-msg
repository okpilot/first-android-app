#!/usr/bin/env bash
# Layer 2 — commit-msg (BLOCKING): Conventional Commits.
# Same intent as LMS Plus's commitlint, without a Node dependency.
set -euo pipefail
first_line="$(head -1 "$1")"

# Let git's own housekeeping commits through.
case "$first_line" in
  "Merge "*|"Revert "*|fixup!*|squash!*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'
if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  cat >&2 <<EOF
✗ Commit message must follow Conventional Commits:
    <type>[optional scope]: <description>
  types: feat fix docs style refactor perf test build ci chore revert
  e.g.   feat(contacts): add search
         docs: sync handover
  got:   ${first_line}
EOF
  exit 1
fi
