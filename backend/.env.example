# Template only — NO real values here. backend/.env is gitignored; NEVER commit
# secrets (CLAUDE.md NEVER-DO). Don't fill this in by hand — run `backend/gen-env.sh`,
# which generates the passwords + JWT secret and a matching anon key into backend/.env.

POSTGRES_DB=postgres
POSTGRES_PASSWORD=<generated by backend/gen-env.sh>       # superuser; dev-only
AUTHENTICATOR_PASSWORD=<generated by backend/gen-env.sh>  # PostgREST login role

# HS256 secret PostgREST validates JWTs against (>= 32 chars).
JWT_SECRET=<generated by backend/gen-env.sh>

# The Supabase "anon" public key = a JWT {"role":"anon"} signed by JWT_SECRET.
# Public by design (ships in the client); gen-env.sh derives it + mirrors it to
# ../dev-defines.json for the Flutter client.
SUPABASE_ANON_KEY=<generated by backend/gen-env.sh>
