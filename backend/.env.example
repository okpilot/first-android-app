# Copy to backend/.env and fill in. backend/.env is gitignored — NEVER commit real
# secrets (CLAUDE.md NEVER-DO). For local dev the values below are fine as-is; the
# helper `backend/gen-env.sh` writes a working .env with a matching anon key.

POSTGRES_DB=postgres
POSTGRES_PASSWORD=postgres-dev-password         # superuser; dev-only
AUTHENTICATOR_PASSWORD=authenticator-dev-pass   # PostgREST login role

# HS256 secret PostgREST validates JWTs against. Must be >= 32 chars.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# The Supabase "anon" public key = a JWT with {"role":"anon"} signed by JWT_SECRET.
# This one is public by design (ships in the client). gen-env.sh regenerates it to
# match JWT_SECRET. Also mirrored to ../dev-defines.json for the Flutter client.
SUPABASE_ANON_KEY=
